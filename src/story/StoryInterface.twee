:: StoryInterface
<div class="rpg-hud"><div class="hud-character"><div class="hud-avatar">{print $playerName[0]}</div><div class="hud-name-level"><div class="hud-name">{$playerName}</div><div class="hud-class-level">{$playerClass} Lv.{$level}</div></div></div><div class="hud-bars">{.hp-bar meter $hp $hpMax "HP"}{.mp-bar meter $mp $mpMax "MP"}{.sta-bar meter $stamina $staminaMax "STA"}</div><div class="hud-gold"><span class="gold-icon">&#x2B22;</span><span>{$gold}</span></div></div>
<div class="combat-indicator">{if $inCombat}<span class="combat-enemy-name">{$currentEnemy}</span>{.enemy-bar meter $enemyHp $enemyHpMax}<span class="combat-enemy-hp">{$enemyHp}/{$enemyHpMax}</span>{/if}</div>
<nav class="rpg-nav" id="rpg-nav"><button class="nav-btn" data-panel="character" aria-label="Character"><span class="nav-icon">&#x1F464;</span><span>Character</span></button><button class="nav-btn" data-panel="skills" aria-label="Skills"><span class="nav-icon">&#x2694;</span><span>Skills</span></button><button class="nav-btn" data-panel="inventory" aria-label="Inventory"><span class="nav-icon">&#x1F392;</span><span>Inventory</span></button><button class="nav-btn" data-panel="journal" aria-label="Journal"><span class="nav-icon">&#x1F4D6;</span><span>Journal</span></button><button class="nav-btn" data-panel="settings" aria-label="Settings"><span class="nav-icon">&#x2699;</span><span>Settings</span></button></nav>
{passage}
